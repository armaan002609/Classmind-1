# VYOM Environment Variables

# Server Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=True

# Persistence (json or sqlite)
PERSISTENCE=json
DATA_DIR=data

# Email Configuration (for Session Reports)
# ----------------------------------------
# Use a Gmail address
EMAIL_ADDRESS=your-email@gmail.com
# IMPORTANT: For Gmail, use an 'App Password', NOT your main login password.
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your-app-password

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=vyom123

# Autosave interval in seconds
AUTOSAVE_INTERVAL=10
# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# AI Lesson Planner & Question Explainer (Optional, server-side fallbacks)
# Set GEMINI_API_KEY to use Google's native Gemini API (Recommended)
# GEMINI_API_KEY=AIzaSy...
# Or set OPENROUTER_API_KEY to use OpenRouter (GPT-4o-mini)
# OPENROUTER_API_KEY=sk-or-v1-...

